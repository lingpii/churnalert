"""
ChurnAlert — Streamlit Cloud App
Deploy lên streamlit.io — Load model siêu tốc bằng file .pkl
"""

import streamlit as st
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import matplotlib; matplotlib.use("Agg")
import joblib
import warnings
warnings.filterwarnings("ignore")

st.set_page_config(page_title="ChurnAlert 🚨", page_icon="🚨", layout="wide", initial_sidebar_state="expanded")

st.markdown("""
<style>
    .stApp { background-color: #0f1117; }
    h1,h2,h3 { color: #58a6ff !important; }
    p,li,label,.stMarkdown { color: #c9d1d9 !important; }
    .metric-card { background:#1a1d27; border:1px solid #2e3250; border-radius:10px; padding:20px; text-align:center; }
    .metric-value { font-size:2.2rem; font-weight:bold; }
    .metric-label { font-size:0.8rem; color:#8b949e; margin-top:6px; }
    .stButton>button { background:#1f6feb; color:white; border:none; border-radius:6px; font-weight:bold; width:100%; }
</style>
""", unsafe_allow_html=True)

ACCENT="#58a6ff"; DANGER="#f85149"; SUCCESS="#3fb950"; WARNING="#d29922"; PURPLE="#bc8cff"

# 🚨 CHỈNH SỬA CHÍNH: Thay thế hàm train bằng hàm load model bằng joblib
@st.cache_resource(show_spinner="🤖 Đang tải mô hình đã huấn luyện (chỉ mất vài mili-giây)...")
def load_model():
    try:
        saved_data = joblib.load("churn_model_v1.pkl")
        return saved_data["model"], saved_data["meta"]
    except FileNotFoundError:
        st.error("Lỗi: Không tìm thấy file 'churn_model_v1.pkl'. Bạn hãy đảm bảo đã copy file model vào cùng thư mục với file app nhé!")
        st.stop()

def preprocess_input(df_raw):
    df = df_raw.copy()
    df = df.drop(columns=["Churn","CustomerID"], errors="ignore")
    if "PreferredLoginDevice" in df.columns: df["PreferredLoginDevice"] = df["PreferredLoginDevice"].replace("Mobile","Mobile Phone")
    if "PreferedOrderCat" in df.columns: df["PreferedOrderCat"] = df["PreferedOrderCat"].replace("Mobile","Mobile Phone")
    if "PreferredPaymentMode" in df.columns: df["PreferredPaymentMode"] = df["PreferredPaymentMode"].replace({"CC":"Credit Card","COD":"Cash on Delivery"})
    if "CouponUsed" in df.columns and "OrderCount" in df.columns: df["coupon_dependency"] = df["CouponUsed"] / (df["OrderCount"]+1e-6)
    if "CashbackAmount" in df.columns and "OrderCount" in df.columns: df["cashback_per_order"] = df["CashbackAmount"] / (df["OrderCount"]+1e-6)
    if "DaySinceLastOrder" in df.columns and "Tenure" in df.columns: df["inactivity_ratio"] = df["DaySinceLastOrder"] / (df["Tenure"]+1e-6)
    if "NumberOfDeviceRegistered" in df.columns and "Tenure" in df.columns: df["device_per_tenure"] = df["NumberOfDeviceRegistered"] / (df["Tenure"]+1e-6)
    return df

def assign_risk(p):
    if p>=0.7: return "🔴 High Risk", DANGER, "Gọi ngay + Giảm giá 20%"
    if p>=0.4: return "🟡 Medium Risk", WARNING, "Email ưu đãi đặc biệt"
    return "🟢 Low Risk", SUCCESS, "Theo dõi — chưa cần action"

with st.sidebar:
    st.markdown("## 🚨 ChurnAlert"); st.markdown("**E-commerce Churn Prediction**")
    st.divider()
    
    # 🚨 Gọi hàm load_model tại đây
    model, meta = load_model()
    
    st.markdown("### 📊 Model")
    st.markdown(f"- ROC AUC: `{meta['roc_auc']}`")
    st.markdown(f"- PR AUC:  `{meta['pr_auc']}`")
    st.markdown(f"- F1:      `{meta['f1']}`")
    st.divider()
    custom_threshold = st.slider("🎯 Threshold", 0.1, 0.9, meta["threshold"], 0.05)
    st.divider()
    st.markdown("🔴 High Risk ≥ 0.70"); st.markdown("🟡 Medium Risk ≥ 0.40"); st.markdown("🟢 Low Risk < 0.40")

st.title("🚨 ChurnAlert — Customer Churn Prediction")
st.markdown("Upload CSV → predict churn → download High Risk list")
st.markdown("---")

col_up, col_tpl = st.columns([3,1])
with col_up:
    st.markdown("### 📂 Upload CSV")
    uploaded = st.file_uploader("Chọn file CSV hoặc Excel", type=["csv","xlsx"])
with col_tpl:
    st.markdown("### 📋 Template")
    sample = pd.DataFrame({"Tenure":[10,2,24],"CityTier":[1,3,2],"WarehouseToHome":[6,14,8],
        "HourSpendOnApp":[3,1,4],"NumberOfDeviceRegistered":[3,2,5],"SatisfactionScore":[4,2,5],
        "NumberOfAddress":[2,5,3],"OrderAmountHikeFromlastYear":[15,25,10],"CouponUsed":[2,8,1],
        "OrderCount":[5,3,12],"DaySinceLastOrder":[3,25,2],"CashbackAmount":[180,90,220],
        "PreferredLoginDevice":["Mobile Phone","Computer","Mobile Phone"],
        "PreferredPaymentMode":["Credit Card","Cash on Delivery","UPI"],
        "Gender":["Male","Female","Male"],"PreferedOrderCat":["Laptop & Accessory","Mobile Phone","Grocery"],
        "MaritalStatus":["Single","Married","Married"],"Complain":[0,1,0]})
    st.download_button("⬇️ Download Template", data=sample.to_csv(index=False).encode(), file_name="template.csv", mime="text/csv")

if uploaded:
    try:
        df_raw = pd.read_excel(uploaded, sheet_name=0) if uploaded.name.endswith(".xlsx") else pd.read_csv(uploaded)
        df_raw = df_raw.drop(columns=["CustomerID"], errors="ignore")
    except Exception as e:
        st.error(f"Lỗi: {e}"); st.stop()

    st.success(f"✅ **{len(df_raw):,} customers** loaded")
    with st.spinner("🔄 Predicting..."):
        X_input = preprocess_input(df_raw)
        y_prob = model.predict_proba(X_input)[:, 1]
        y_pred = (y_prob >= custom_threshold).astype(int)
        tiers, colors_list, actions = zip(*[assign_risk(p) for p in y_prob])
        results = df_raw.copy()
        results.insert(0,"customer_id",range(1,len(results)+1))
        results["churn_prob"] = y_prob.round(4)
        results["churn_predicted"] = y_pred
        results["risk_tier"] = tiers
        results["recommended_action"] = actions

    st.markdown("---")
    n_h = sum(1 for t in tiers if "High" in t)
    n_m = sum(1 for t in tiers if "Medium" in t)
    n_l = sum(1 for t in tiers if "Low" in t)
    c1,c2,c3,c4,c5 = st.columns(5)
    for col,val,label,color in [(c1,f"{len(results):,}","Total",ACCENT),(c2,f"{n_h:,}","🔴 High Risk",DANGER),(c3,f"{n_m:,}","🟡 Medium",WARNING),(c4,f"{n_l:,}","🟢 Low Risk",SUCCESS),(c5,f"{y_pred.mean()*100:.1f}%","Churn Rate",PURPLE)]:
        with col: st.markdown(f'''<div class="metric-card"><div class="metric-value" style="color:{color}">{val}</div><div class="metric-label">{label}</div></div>''', unsafe_allow_html=True)
    st.markdown("")

    ch1,ch2 = st.columns(2)
    with ch1:
        fig,ax = plt.subplots(figsize=(5,4)); fig.patch.set_facecolor("#1a1d27"); ax.set_facecolor("#1a1d27")
        tc = pd.Series(tiers).value_counts(); bc = {"🔴 High Risk":DANGER,"🟡 Medium Risk":WARNING,"🟢 Low Risk":SUCCESS}
        for t,c in tc.items():
            ax.bar(t,c,color=bc.get(t,ACCENT),width=0.5); ax.text(t,c+1,f"{c:,}",ha="center",color="#c9d1d9",fontsize=10,fontweight="bold")
        ax.set_ylabel("Count",color="#8b949e"); ax.tick_params(colors="#8b949e"); ax.grid(axis="y",alpha=0.2)
        for s in ax.spines.values(): s.set_edgecolor("#2e3250")
        plt.tight_layout(); st.pyplot(fig); plt.close()
    with ch2:
        fig,ax = plt.subplots(figsize=(5,4)); fig.patch.set_facecolor("#1a1d27"); ax.set_facecolor("#1a1d27")
        ax.hist(y_prob,bins=30,color=ACCENT,alpha=0.8,edgecolor="none")
        ax.axvline(custom_threshold,color=DANGER,lw=2,linestyle="--",label=f"Threshold={custom_threshold:.2f}")
        ax.axvline(y_prob.mean(),color=WARNING,lw=1.5,linestyle="--",label=f"Mean={y_prob.mean():.3f}")
        ax.set_xlabel("Churn Prob",color="#8b949e"); ax.tick_params(colors="#8b949e")
        ax.legend(facecolor="#1a1d27",edgecolor="#2e3250",labelcolor="#c9d1d9",fontsize=9)
        for s in ax.spines.values(): s.set_edgecolor("#2e3250")
        plt.tight_layout(); st.pyplot(fig); plt.close()

    st.markdown("---"); st.markdown("### 📋 Results")
    f1,f2,f3 = st.columns([2,2,1])
    with f1: tf = st.multiselect("Filter Tier",["🔴 High Risk","🟡 Medium Risk","🟢 Low Risk"],default=["🔴 High Risk","🟡 Medium Risk","🟢 Low Risk"])
    with f2: pr = st.slider("Prob Range",0.0,1.0,(0.0,1.0),0.05)
    with f3: sc = st.selectbox("Sort",["churn_prob ↓","customer_id ↑"])
    filt = results[results["risk_tier"].isin(tf)&(results["churn_prob"]>=pr[0])&(results["churn_prob"]<=pr[1])].sort_values("churn_prob",ascending=(sc!="churn_prob ↓"))
    cols = ["customer_id","churn_prob","risk_tier","recommended_action"]+[c for c in ["Tenure","SatisfactionScore","Complain","CashbackAmount"] if c in filt.columns]
    st.dataframe(filt[cols].reset_index(drop=True),use_container_width=True,height=380)
    st.caption(f"**{len(filt):,}** / **{len(results):,}** customers")

    st.markdown("---")
    d1,d2 = st.columns(2)
    with d1: st.download_button("⬇️ Full Results",data=results.to_csv(index=False).encode(),file_name="churn_predictions.csv",mime="text/csv",use_container_width=True)
    with d2:
        hr = results[results["risk_tier"]=="🔴 High Risk"]
        st.download_button(f"⬇️ High Risk Only ({n_h})",data=hr.to_csv(index=False).encode(),file_name="high_risk.csv",mime="text/csv",use_container_width=True)

    st.markdown("---"); st.markdown("### 🔍 SHAP Explanation")
    s1,s2 = st.columns([1,2])
    with s1:
        idx = st.selectbox("Chọn customer:",range(len(results)),format_func=lambda i: f"#{results.iloc[i]['customer_id']} prob={results.iloc[i]['churn_prob']:.3f} {results.iloc[i]['risk_tier']}")
        r = results.iloc[idx]
        st.markdown(f"**#{int(r['customer_id'])}** | `{r['churn_prob']:.4f}` | {r['risk_tier']}\n\n*{r['recommended_action']}*")
        shap_btn = st.button("🔍 Explain này")
    with s2:
        if shap_btn:
            with st.spinner("Calculating..."):
                try:
                    import shap
                    inner = model.estimator; prep = inner.named_steps["preprocessor"]; xgb_c = inner.named_steps["classifier"]
                    X_t = prep.transform(X_input); cat_e = prep.named_transformers_["cat"]
                    cat_n = cat_e.get_feature_names_out(X_input.select_dtypes(include=["object","category"]).columns.tolist())
                    all_n = X_input.select_dtypes(include=[np.number]).columns.tolist()+list(cat_n)
                    X_df = pd.DataFrame(X_t,columns=all_n)
                    exp_s = shap.TreeExplainer(xgb_c); sv = exp_s.shap_values(X_df)
                    bv = float(np.array(exp_s.expected_value).squeeze())
                    exp = shap.Explanation(values=sv[idx],base_values=bv,data=X_df.iloc[idx].values,feature_names=all_n)
                    fig,_ = plt.subplots(figsize=(10,6)); fig.patch.set_facecolor("#1a1d27")
                    shap.plots.waterfall(exp,show=False); plt.tight_layout(); st.pyplot(fig); plt.close()
                except Exception as e: st.error(f"SHAP: {e}")
else:
    st.info("👆 Upload CSV để bắt đầu — hoặc download Template")
    c1,c2,c3,c4 = st.columns(4)
    for col,icon,title,desc in [(c1,"📂","Upload","Raw data"),(c2,"⚙️","Preprocess","Encode+Impute"),(c3,"🤖","Predict","Prob+Risk"),(c4,"🔍","SHAP","Explain")]:
        with col: st.markdown(f'''<div class="metric-card"><div style="font-size:2rem">{icon}</div><div style="color:#58a6ff;font-weight:bold;margin:8px 0">{title}</div><div style="font-size:0.8rem;color:#8b949e">{desc}</div></div>''', unsafe_allow_html=True)
